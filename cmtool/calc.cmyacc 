sml
name CalcParseFun

terminal NUMBER of t
terminal PLUS
terminal TIMES
terminal LPAREN
terminal RPAREN

nonterminal Atom : t =
  1:NUMBER => number_atom
  PLUS 1:Term PLUS => plus_atom

nonterminal Factor : t =
  1:Atom => atom_factor
  1:Atom PAREN 2:Factor => paren_factor

nonterminal Term : t =
  1:Factor => factor_term
  1:Factor TIMES 2:Term => times_term

start Term